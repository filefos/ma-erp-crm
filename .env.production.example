# =============================================================
# MA ERP-CRM — Production environment template
# Copy to .env.production and fill in every CHANGE_ME value.
# DO NOT commit the filled file. chmod 600 .env.production
# =============================================================

NODE_ENV=production

# ---- Network ----
# API server binds to this port on 127.0.0.1 — Nginx proxies /api to it
PORT=8080
# Vite base path for the built static bundle (use "/" for root)
BASE_PATH=/

# ---- Database ----
DATABASE_URL=postgres://erp_user:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/ma_erp

# ---- Auth ----
# Generate with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARS
# Cookie domain = the domain users hit
COOKIE_DOMAIN=erp.yourcompany.com
# Set to "true" once HTTPS is active (after step 11 in DEPLOYMENT.md)
COOKIE_SECURE=true

# ---- Logging ----
LOG_LEVEL=info

# ---- SMTP (for the email module) ----
SMTP_HOST=business500.mypowerfulserver.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=sales@primemaxprefab.com
SMTP_PASS=CHANGE_ME
SMTP_FROM_NAME=PRIME MAX

# ---- IMAP (for inbox sync) ----
IMAP_HOST=business500.mypowerfulserver.com
IMAP_PORT=993
IMAP_SECURE=ssl
IMAP_USER=sales@primemaxprefab.com
IMAP_PASS=CHANGE_ME

# ---- WhatsApp Business Cloud API (optional) ----
WHATSAPP_ACCESS_TOKEN=CHANGE_ME_OR_LEAVE_BLANK
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ---- File storage ----
# Option A: keep using Replit Object Storage (carry these over from Replit Secrets)
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# Option B: local disk (uncomment to use, and update objectStorage.ts accordingly)
# UPLOAD_DIR=/home/deploy/apps/ma-erp/uploads
