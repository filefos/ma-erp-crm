# ─── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://erp_user:your_password@localhost:5432/erp_db

# JWT signing secret — use a long random string (e.g. openssl rand -hex 64)
SESSION_SECRET=replace-with-64-char-random-string

# API server port
PORT=8080

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Leave unset to allow all origins (development only)
ALLOWED_ORIGIN=https://yourdomain.com

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ─── WhatsApp Cloud API (optional) ────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your-permanent-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# Set in Meta Developer Console → Webhooks → Verify Token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
# Used to verify HMAC signature on incoming webhook events
WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# ─── Expo Push Notifications (optional) ──────────────────────────────────────
EXPO_ACCESS_TOKEN=your-expo-access-token

# ─── AI Integration (optional) ────────────────────────────────────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_MODEL=gpt-4o

# ─── Object / File Storage (optional) ────────────────────────────────────────
# Absolute paths on the VPS filesystem for private/public file storage
PRIVATE_OBJECT_DIR=/var/erp/private
PUBLIC_OBJECT_SEARCH_PATHS=/var/erp/public

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production

# ─── Security / Notifications (optional) ─────────────────────────────────────
# Secret token for admin deploy endpoint
DEPLOY_SECRET=your-deploy-secret

# Login alert email (sent when super admin logs in from new IP)
LOGIN_NOTIFY_EMAIL=alert@yourdomain.com
