{
  "expo": {
    "name": "PRIME ERP SYSTEM",
    "slug": "prime-erp-",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "primeerp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.primemax.erpsystem"
    },
    "android": {
      "package": "com.primemax.erpsystem",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://primerpsystem.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PRIME ERP SYSTEM uses your location to record GPS-verified attendance check-ins for the sales team."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "PRIME ERP SYSTEM uses the camera to capture an on-site selfie for verified attendance.",
          "photosPermission": "PRIME ERP SYSTEM uses your photos to attach receipts and supporting documents."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#EA580C"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "filefos",
    "extra": {
      "eas": {
        "projectId": "824dde53-3c5e-429a-8296-a75aa5ed8b56"
      }
    }
  }
}