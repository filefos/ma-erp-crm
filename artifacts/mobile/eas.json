{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "pnpm": "10.26.1",
      "android": {
        "buildType": "apk",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "primerpsystem.com",
        "NODE_VERSION": "20"
      }
    },
    "preview": {
      "distribution": "internal",
      "pnpm": "10.26.1",
      "android": {
        "buildType": "apk",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "primerpsystem.com",
        "NODE_VERSION": "20"
      }
    },
    "production": {
      "pnpm": "10.26.1",
      "android": {
        "buildType": "app-bundle",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "primerpsystem.com",
        "NODE_VERSION": "20"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}